---
import sansWoff2 from "@/assets/fonts/IBMPlexSans-VariableFont_wdth,wght.woff2?url"
import sansItalicWoff2 from "@/assets/fonts/IBMPlexSans-Italic-VariableFont_wdth,wght.woff2?url"
import { SITE } from "@/consts"
import { ClientRouter } from "astro:transitions"
---

<head>
  <meta charset="utf-8">
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, user-scalable=yes"
  >
  <meta name="generator" content={Astro.generator}>
  <ClientRouter />

  <meta name="HandheldFriendly" content="True">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content={SITE.title}>
  <meta
    name="format-detection"
    content="telephone=no,date=no,address=no,email=no,url=no"
  >

  <meta name="theme-color" content="#0a0a0a">

  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon-96x96.png`.replace(/\/\/+/g, '/')} sizes="96x96">
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon.png`.replace(/\/\/+/g, '/')}>
  <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}/apple-touch-icon.png`.replace(/\/\/+/g, '/')}>
  <link rel="manifest" href={`${import.meta.env.BASE_URL}/site.webmanifest`.replace(/\/\/+/g, '/')}>

  <link rel="sitemap" href="/sitemap-index.xml">
  <link
    rel="alternate"
    type="application/rss+xml"
    title={SITE.title}
    href={new URL("rss.xml", Astro.site)}
  >

  <link rel="preload" href={sansWoff2} as="font" type="font/woff2" crossorigin>
  <link
    rel="preload"
    href={sansItalicWoff2}
    as="font"
    type="font/woff2"
    crossorigin
  >

  <script is:inline>
    document.documentElement.dataset.theme = "dark"
  </script>

  <slot />
</head>
