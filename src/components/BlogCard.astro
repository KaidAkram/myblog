---
import { formatDate } from "@/lib/utils"
import { Image } from "astro:assets"
import { getEntries, type CollectionEntry } from "astro:content"

type Props = { post: CollectionEntry<"blog"> }

const { post } = Astro.props
const authors = await getEntries(post.data.authors)
---

<li>
  {post.data.image && (
      <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} tabindex="-1" aria-hidden="true">
        <Image src={post.data.image} alt="" width={640} height={336} />
      </a>
    )}
  <entry-info>
    <a href={`${import.meta.env.BASE_URL}blog/${post.id}`}>{post.data.title}</a>
    <entry-meta>
      {authors.length > 0 && (
          <entry-authors>
            <author-avatars>
              {authors.map((author) => (
                <img
                  src={author.data.avatar}
                  alt={author.data.name}
                  width="18"
                  height="18"
                />
              ))}
            </author-avatars>
            <author-names>
              {authors.map((author, i) => (
                <>{i > 0 && ", "}{author.data.name}</>
              ))}
            </author-names>
          </entry-authors>
        )}
      <time datetime={post.data.date.toISOString()}
        >{formatDate(post.data.date)}</time
      >
      {post.data.tags && (
          <entry-tags>
            {post.data.tags.map((tag) => (
              <a href={`https://www.reddit.com/search/?q=${encodeURIComponent(tag + ' cybersecurity')}&safe=on`} target="_blank" rel="noopener noreferrer">#{tag}</a>
            ))}
          </entry-tags>
        )}
    </entry-meta>
    <p>{post.data.description}</p>
  </entry-info>
</li>

<style>
  li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-s);

    > a {
      flex-shrink: 0;
      inline-size: 14rem;

      :global(img) {
        inline-size: 100%;
        block-size: auto;
        border-radius: 4px;
        border: 1px solid var(--border);
      }
    }

    entry-info {
      display: flex;
      flex-direction: column;

      > a {
        font-size: var(--step-1);
        line-height: 1.2;
        font-weight: var(--font-weight-medium);
        margin-top: -0.15rem; /* Aligns text cleanly with the top of the image */
      }

      entry-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-3xs);
        margin-block-end: var(--space-3xs);
        font-size: var(--step--1);
        color: var(--muted-foreground);

        entry-authors {
          display: flex;
          align-items: center;
          gap: var(--space-3xs);

          author-avatars {
            display: flex;
            margin-block-end: -0.1em;

            img {
              border-radius: var(--radius-full);
              box-shadow: 0 0 0 1.5px var(--background);

              &:not(:first-child) {
                margin-inline-start: -0.375rem;
              }
            }
          }
        }

        entry-authors ~ time::before {
          content: "·";
          margin-inline-end: var(--space-3xs);
        }

        entry-tags {
          display: flex;
          flex-wrap: wrap;
          gap: var(--space-3xs);

          a {
            color: color-mix(
              in oklab,
              var(--muted-foreground) 50%,
              transparent
            );
            text-decoration: none;

            &:hover {
              color: var(--foreground);
            }
          }
        }

        time ~ entry-tags::before {
          content: "·";
        }
      }

      p {
        color: var(--muted-foreground);
      }
    }

    @media (width < 40rem) {
      flex-direction: column;

      > a {
        inline-size: 100%;
        max-inline-size: 32rem;
      }
    }
  }
</style>
